# Sample nginx site for TTSMaker Clone. Place in /etc/nginx/sites-available/
# and symlink into sites-enabled/, then `sudo nginx -t && sudo systemctl reload nginx`.
#
# TLS termination is intentionally omitted here — use certbot:
#     sudo certbot --nginx -d your-domain.com

upstream ttsmaker_app {
    server 127.0.0.1:8000 fail_timeout=0;
}

server {
    listen 80;
    server_name your-domain.com;

    # Audio files can grow above the default 1m client_max_body_size.
    client_max_body_size 2m;

    # Static files are served by WhiteNoise in-process, but if you prefer
    # nginx to serve them directly, uncomment the block below and run
    # `python manage.py collectstatic`.
    #
    # location /static/ {
    #     alias /opt/ttsmaker-clone/staticfiles/;
    #     expires 7d;
    #     access_log off;
    # }

    location / {
        proxy_pass http://ttsmaker_app;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
        proxy_connect_timeout 5s;
    }
}
