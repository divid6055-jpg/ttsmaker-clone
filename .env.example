# =============================================================================
# TTSMaker Clone - Environment Variables Example
# Copy this file to .env and adjust the values for your deployment.
# NEVER commit the real .env file to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Core Django settings
# ---------------------------------------------------------------------------

# Generate a strong random key, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string

# Set to "False" for production. Default is False if not provided.
DJANGO_DEBUG=False

# Comma-separated list of hosts/domains the app will serve.
# Examples: "example.com,www.example.com" or "127.0.0.1,localhost"
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Comma-separated list of trusted origins for CSRF (must include scheme).
# Example: "https://example.com,https://www.example.com"
DJANGO_CSRF_TRUSTED_ORIGINS=

# Comma-separated list of CORS-allowed origins (must include scheme).
# Leave empty to disallow cross-origin requests by default.
# Example: "https://example.com,https://app.example.com"
DJANGO_CORS_ALLOWED_ORIGINS=

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Default is SQLite in BASE_DIR. For PostgreSQL set DATABASE_URL like:
#   postgres://user:password@host:5432/dbname
# (Requires installing dj-database-url + psycopg2 if you change this.)
DATABASE_URL=

# ---------------------------------------------------------------------------
# TTS engine configuration
# ---------------------------------------------------------------------------

# Which engine to use by default: "edge" (recommended) or "gtts".
TTS_DEFAULT_ENGINE=edge

# Whether ffmpeg is installed and available on PATH.
# When True, the app can convert MP3 -> WAV/OGG/AAC using pydub+ffmpeg.
# When False, the app will reject non-MP3 formats with a clear error.
FFMPEG_AVAILABLE=False

# ---------------------------------------------------------------------------
# Quota / rate limiting
# ---------------------------------------------------------------------------

# Maximum characters a single anonymous user (per IP) may convert per day.
FREE_DAILY_CHAR_LIMIT=20000

# Maximum characters per single TTS request (hard cap).
MAX_CHARS_PER_REQUEST=5000

# Maximum TTS requests per IP per minute (rate limit).
TTS_RATE_LIMIT_PER_MINUTE=10

# How long (in seconds) generated audio files are kept before cleanup.
AUDIO_FILE_TTL_SECONDS=7200

# ---------------------------------------------------------------------------
# Security headers (only used when DEBUG=False)
# ---------------------------------------------------------------------------
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
